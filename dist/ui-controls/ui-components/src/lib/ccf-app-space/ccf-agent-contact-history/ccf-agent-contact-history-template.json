{
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "type": "AdaptiveCard",
    "version": "1.5",
    "verticalContentAlignment": "Center",
    "speak": "${contactName} ${skill} ${statusUpdatedDateTime} ${dispositionStatus}",
    "selectAction": {
        "type": "Action.Execute",
        "title": "Select Activity",
        "tooltip": "${contactName}"
    },
    "body": [
        {
            "id": "activityCard",
            "type": "ColumnSet",
            "columns": [
                {
                    "type": "Column",
                    "id": "interactionNameAndChannelContainer",
                    "width": 30,
                    "items": [
                        {
                            "type": "Container",
                            "id": "contactNumberContainer",
                            "items": [
                                {
                                    "id": "ccfAppSpaceActivityContactNumber",
                                    "type": "TextBlock",
                                    "weight": "Bolder",
                                    "text": "${contactName}",
                                    "spacing": "None",
                                    "horizontalAlignment": "Left",
                                    "fontType": "Default",
                                    "size": "Default",
                                    "isSubtle": true
                                }
                            ]
                        },
                        {
                            "type": "ColumnSet",
                            "columns": [
                                {
                                    "type": "Column",
                                    "items": [
                                        {
                                            "id": "${mediaType=='Digital'?'activityIcon':'activityIconvoice'}",
                                            "type": "Image",
                                            "url": "${channelIcon}",
                                            "size": "Small",
                                            "altText": "${channelAltTxt}"
                                        }
                                    ],
                                    "width": "auto"
                                },
                                {
                                    "type": "Column",
                                    "items": [
                                        {
                                            "type": "TextBlock",
                                            "id": "skillName",
                                            "spacing": "Small",
                                            "text": "${skill}",
                                            "size": "Small",
                                            "wrap": true
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "Column",
                    "id": "statusAndTimestampContainer",
                    "items": [
                        {
                            "type": "Container",
                            "items": [
                                {
                                    "id": "contactHistoryDateString",
                                    "type": "RichTextBlock",
                                    "horizontalAlignment": "Left",
                                    "inlines": [
                                        {
                                            "type": "TextRun",
                                            "text": "${$data.integratedView?statusUpdatedDate:statusUpdatedDateTime}",
                                            "size": "Small",
                                            "color": "Default",
                                            "weight": "Bolder",
                                            "isSubtle": true
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "id": "positive",
                            "type": "TextBlock",
                            "weight": "Default",
                            "text": "${dispositionStatus}",
                            "size": "Small",
                            "horizontalAlignment": "Left",
                            "isSubtle": true
                        }
                    ],
                    "style": "default",
                    "separator": true
                }
            ],
            "horizontalAlignment": "Left",
            "separator": true,
            "spacing": "Small",
            "bleed": true
        }
    ]
}
